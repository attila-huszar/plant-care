{
  "info": {
    "_postman_id": "0f1e0c88-9d76-4c5c-bbe0-0d6f9d7c78a7",
    "name": "Plant Care API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "email", "value": "user@example.com" },
    { "key": "password", "value": "test1234" },
    { "key": "mfaCode", "value": "000000" },
    { "key": "token", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "plantId", "value": "1" },
    { "key": "eventId", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}",
                  "if (json && json.mfaPending) {",
                  "  pm.collectionVariables.set('email', json.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/login"
          }
        },
        {
          "name": "MFA verify",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"code\": \"{{mfaCode}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/mfa-verify"
          }
        },
        {
          "name": "Register (multipart/form-data)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "firstName", "value": "Test", "type": "text" },
                { "key": "lastName", "value": "User", "type": "text" },
                { "key": "email", "value": "{{email}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/api/users/register"
          }
        },
        {
          "name": "Verification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/verification"
          }
        },
        {
          "name": "Password reset request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/password-reset-request"
          }
        },
        {
          "name": "Password reset token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/password-reset-token"
          }
        },
        {
          "name": "Password reset submit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/password-reset-submit"
          }
        },
        {
          "name": "Refresh access token (cookie-based)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/users/refresh"
          }
        },
        {
          "name": "Get profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/profile"
          }
        },
        {
          "name": "Update profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\"\n}"
            },
            "url": "{{baseUrl}}/api/users/profile"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/users/logout"
          }
        }
      ]
    },
    {
      "name": "Plants",
      "item": [
        {
          "name": "List plants",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/plants"
          }
        },
        {
          "name": "Create plant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.id != null) {",
                  "  pm.collectionVariables.set('plantId', String(json.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monstera\",\n  \"careRules\": [\n    {\n      \"kind\": \"recurring\",\n      \"id\": \"00000000-0000-0000-0000-000000000000\",\n      \"type\": \"Water\",\n      \"days\": 7,\n      \"notes\": \"Weekly\"\n    }\n  ],\n  \"imageUrl\": null\n}"
            },
            "url": "{{baseUrl}}/api/plants"
          }
        },
        {
          "name": "Update plant",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monstera (updated)\"\n}"
            },
            "url": "{{baseUrl}}/api/plants/{{plantId}}"
          }
        },
        {
          "name": "Delete plant",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/plants/{{plantId}}"
          }
        },
        {
          "name": "Create event",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.event && json.event.id != null) {",
                  "  pm.collectionVariables.set('eventId', String(json.event.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"Water\",\n  \"date\": \"2026-01-01T12:00:00.000Z\",\n  \"notes\": \"Did it\"\n}"
            },
            "url": "{{baseUrl}}/api/plants/{{plantId}}/events"
          }
        },
        {
          "name": "Delete event",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/plants/{{plantId}}/events/{{eventId}}"
          }
        }
      ]
    }
  ]
}
